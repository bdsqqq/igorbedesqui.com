{
  "name": "igorbedesqui-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.11.0 <25"
  },
  "scripts": {
    "dev": "vp run @igorbedesqui/web#dev",
    "build": "vp run @igorbedesqui/web#build",
    "preview": "vp run @igorbedesqui/web#preview",
    "start": "vp run @igorbedesqui/web#start",
    "check": "vp run @igorbedesqui/web#routes:generate && vp check apps/web",
    "check:fix": "vp run @igorbedesqui/web#routes:generate && vp check --fix apps/web",
    "lint:github": "vp run @igorbedesqui/web#routes:generate && vp lint --format=github apps/web"
  },
  "devDependencies": {
    "vite-plus": "0.2.4"
  },
  "license": "MIT"
}
