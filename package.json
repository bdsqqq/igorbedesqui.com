{
  "name": "igorbedesqui-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "pnpm --filter @igorbedesqui/web dev",
    "build": "pnpm --filter @igorbedesqui/web build",
    "preview": "pnpm --filter @igorbedesqui/web preview",
    "start": "pnpm --filter @igorbedesqui/web start",
    "lint": "pnpm --filter @igorbedesqui/web lint",
    "lint:fix": "pnpm --filter @igorbedesqui/web lint:fix",
    "lint:github": "pnpm --filter @igorbedesqui/web lint:github",
    "fmt": "pnpm --filter @igorbedesqui/web fmt",
    "fmt:check": "pnpm --filter @igorbedesqui/web fmt:check"
  },
  "license": "MIT"
}
